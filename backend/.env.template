NODE_ENV=development
# Enable POST /store/carts/:id/complete-deferred (order without payment/shipping; admin completes later)
# STORE_DEFERRED_CHECKOUT=true
# Staff alert when a customer places an order (order.placed). Comma-separated OK. Falls back to STORE_SUPPORT_EMAIL if unset.
# ADMIN_ORDER_NOTIFICATION_EMAIL=ops@example.com
# Optional; used as support/from hints and as fallback for admin new-order emails
# STORE_SUPPORT_EMAIL=support@example.com
# Deferred invoice email (admin): payment link base, e.g. https://your-store.com — used as {{storefront_url}} in template
# STOREFRONT_URL=https://your-storefront.example
# Optional Handlebars URL override: {{storefront_url}} {{order_id}} {{order_display_id}} {{payment_collection_id}}
# DEFERRED_INVOICE_PAYMENT_URL_TEMPLATE={{storefront_url}}/checkout/pay?order={{order_id}}&pc={{payment_collection_id}}
# REDIS_URL=redis://localhost:6379 # Optional - falls back to simulated redis
# Admin "Sparti Pages" / embedded iframes (Vite: must be VITE_*). JSON array of { "label", "url" }:
# VITE_ADMIN_EMBEDDED_SITES=[{"label":"Docs","url":"https://docs.medusajs.com"},{"label":"Example","url":"https://example.com"}]
# Or a single URL (label defaults to "Embedded"):
# VITE_ADMIN_EMBEDDED_SITE_URL=https://www.example.com

ADMIN_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
AUTH_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa # Make sure this database exist - or change connection string to an online database

MEDUSA_ADMIN_EMAIL=admin@yourmail.com
MEDUSA_ADMIN_PASSWORD=supersecret

STRIPE_API_KEY=
# Required with STRIPE_API_KEY — Stripe payment module does not load without both
STRIPE_WEBHOOK_SECRET=

# HitPay (optional — all three required to load provider; register webhook in HitPay dashboard: {BACKEND_URL}/hooks/payment/hitpay_hitpay, event payment_request.completed)
# HITPAY_API_KEY=
# HITPAY_SALT=
# HITPAY_REDIRECT_URL=https://your-storefront.example/order/confirmation
# HITPAY_SANDBOX=true

# Required for GET /key-exchange — use Authorization: Bearer ... or x-medusa-key-exchange-secret
# KEY_EXCHANGE_SECRET=

# Notification email languages: comma-separated BCP47 codes (e.g. en,de). When set, overrides store metadata for which locales appear in admin and for fallbacks.
# NOTIFICATION_EMAIL_LOCALES=en,de
# Optional default when order.metadata.locale is missing or not in the list (must be one of the configured locales).
# NOTIFICATION_EMAIL_DEFAULT_LOCALE=en
# If NOTIFICATION_EMAIL_LOCALES is unset: store.metadata.supported_notification_locales as string[] or comma-separated string.

SENDGRID_API_KEY=
SENDGRID_FROM=

# MinIO Storage Configuration (Optional - falls back to local storage)
# MINIO_ENDPOINT=your-minio-endpoint
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=custom-bucket-name # Optional - defaults to 'medusa-media'

# Meilisearch Configuration (Optional)
# MEILISEARCH_HOST=your-meilisearch-host # e.g. http://localhost:7700
# MEILISEARCH_MASTER_KEY=your-master-key # Required if MEILISEARCH_ADMIN_KEY is not set
# MEILISEARCH_ADMIN_KEY=your-admin-key # Optional - if not set, will be fetched using master key

# Price fallback when cart currency has no matching variant price (patched core-flows; ISO 4217, lowercase ok)
# WCWP_FALLBACK_CURRENCY=eur

# WooCommerce API import (Optional — all three required to use server-side credentials)
# WC_API_URL=https://your-store.com
# WC_CONSUMER_KEY=ck_...
# WC_CONSUMER_SECRET=cs_...

# DeepL product translations → product metadata JSON key `i18n` (POST /admin/products/:id/translate or auto subscriber)
# DEEPL_AUTH_KEY=
# DEEPL_API_BASE=https://api-free.deepl.com/v2
# Pro accounts often use: DEEPL_API_BASE=https://api.deepl.com/v2
# DEEPL_SOURCE_LANG=EN
# DEEPL_TARGET_LANGS=DE,FR
# DEEPL_AUTO_TRANSLATE_ON_PRODUCT_UPDATE=false
